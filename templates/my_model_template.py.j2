def _on_message(_client, _userdata, msg):
    if _max_messages is not None and len(_msgs) >= _max_messages:
        return
    payload_s = msg.payload.decode("utf-8", errors="ignore")
    base = {"topic": msg.topic, "raw": payload_s}
    extra = _parse_kv_payload(payload_s)
    base.update(extra)
    _msgs.append(base)

client_{{ QNAME }} = mqtt.Client(client_id=_client_id, clean_session=True)
client_{{ QNAME }}.on_message = _on_message

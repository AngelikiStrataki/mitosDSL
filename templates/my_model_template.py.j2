client_{{ QNAME }}.loop_start()

_start = time.time()
while True:
    if _max_messages is not None and len(_msgs) >= _max_messages:
        break
    if (time.time() - _start) >= _capture_seconds:
        break
    time.sleep(0.05)

client_{{ QNAME }}.loop_stop()
data = list(_msgs)
data = _apply_alias_prefix(data, "{{ FROM_ALIAS }}")


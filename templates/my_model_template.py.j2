def _sort_key(val):
    if val is None:
        return (2, "")
    if isinstance(val, (int, float)):
        return (0, val)
    s = str(val).strip()
    num_like = s.replace('-', '', 1).replace('.', '', 1)
    if num_like.isdigit():
        try:
            return (0, float(s))
        except Exception:
            pass
    return (1, s.casefold())


{% macro sql_emit(node) -%}
{%- set T = node.__class__.__name__ -%}
{%- if T == 'OrExpr' -%}
( {{ sql_emit(node.left) }}{% for ch in node.rights %} OR {{ sql_emit(ch.right) }}{% endfor %} )
{%- elif T == 'AndExpr' -%}
( {{ sql_emit(node.left) }}{% for ch in node.rights %} AND {{ sql_emit(ch.right) }}{% endfor %} )
{%- elif T == 'NotExpr' -%}
{%- set odd = (node.negs|length) % 2 -%}

{% set OFF = (query.offset.value if query.offset and query.offset.value is defined else None) %}

{% if LIM is not none and OFF is not none %}
results = results[ {{ OFF }} : {{ OFF + LIM }} ]
{% elif LIM is not none %}
results = results[: {{ LIM }} ]
{% elif OFF is not none %}
results = results[ {{ OFF }} : ]
{% endif %}

{% endif %}

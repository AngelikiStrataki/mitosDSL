{%- if node.inner -%}
( {{ sql_emit(node.inner) }} )
{%- else -%}
( {{ sql_emit(node.cmp) }} )
{%- endif -%}
{%- elif T == 'Comparison' -%}
( {{ sql_operand(node.left) }} {{ node.op }} {{ sql_operand(node.right) }} )
{%- else -%}

{% macro emit(node) -%}
{%- set T = node.__class__.__name__ -%}
{%- if T == 'OrExpr' -%}
__OR([ {{ emit(node.left) }}{% for ch in node.rights %}, {{ emit(ch.right) }}{% endfor %} ])
{%- elif T == 'AndExpr' -%}
__AND([ {{ emit(node.left) }}{% for ch in node.rights %}, {{ emit(ch.right) }}{% endfor %} ])
{%- elif T == 'NotExpr' -%}
{%- set odd = (node.negs|length) % 2 -%}
{%- if odd -%}
(not ( {{ emit(node.term) }} ))
{%- else -%}
( {{ emit(node.term) }} )
{%- endif -%}
{%- elif T == 'Predicate' -%}
{%- if node.inner -%}
( {{ emit(node.inner) }} )
{%- else -%}
( {{ emit(node.cmp) }} )
{%- endif -%}
{%- elif T == 'Comparison' -%}
__cmp("{{ _op_map.get(node.op, node.op) }}",
      __to_num_if_numeric({{ emit_operand(node.left) }}),
      __to_num_if_numeric({{ emit_operand(node.right) }}) )
{%- else -%}
True
{%- endif -%}
{%- endmacro %}

{% if query.where and query.where.expr %}
_tmp_filtered = []
for row in data:
    if {{ emit(query.where.expr) }}:
        _tmp_filtered.append(row)
filtered = _tmp_filtered
{% else %}
filtered = data
{% endif %}

GB_FULL = [
{% if query.groupBy and query.groupBy.fields -%}
{%- for g in query.groupBy.fields -%}
"{{ join_qname(g) }}"{% if not loop.last %}, {% endif -%}
{%- endfor -%}
{%- endif %}
]

GB_BASE = [
{% if query.groupBy and query.groupBy.fields -%}
{%- for g in query.groupBy.fields -%}
"{{ last_id(g) }}"{% if not loop.last %}, {% endif -%}
{%- endfor -%}
{%- endif %}
]

GB_OUT = [
{% if query.groupBy and query.groupBy.fields -%}
{%- for g in query.groupBy.fields -%}
"{{ BASE_ALIAS_DICT.get(last_id(g), last_id(g)) }}"{% if not loop.last %}, {% endif %}
{%- endfor -%}
{%- endif %}
]

HAS_GROUPS = True if GB_FULL else False
HAS_AGGS   = {{ 'True' if (query.aggregates and query.aggregates.aggs and (query.aggregates.aggs|length>0)) else 'False' }}

def _compute_aggs_{{ QNAME }}(rows):
    result_aggs = {}
{% if query.aggregates and query.aggregates.aggs %}
{% for a in query.aggregates.aggs %}
    _rows_for_agg = rows
    {% set W = a.window.__class__.__name__ %}
    {% if W == 'AllRowsWindow' %}
    _rows_for_agg = rows
    {% elif W == 'SampleWindow' %}
    _rows_for_agg = _apply_window(rows, None, "samples", {{ a.window.value }})
    {% elif W == 'TimeWindow' %}
    _rows_for_agg = _apply_window(rows, None, "time", {{ a.window.value }}, "{{ a.window.unit }}")
    {% else %}
    _rows_for_agg = rows
    {% endif %}

    _func = "{{ a.func }}"
    {% if a.wildcard is defined and a.wildcard %}
    if _func == 'count':
        _val = len(_rows_for_agg)
    else:
        _val = None
    {% else %}
    _field_full = "{{ join_qname(a.field) }}"
    _field_base = "{{ last_id(a.field) }}"
    if _func == 'count':
        _val = sum(1 for _r in _rows_for_agg if _get_q(_r, _field_full, _field_base) is not None)
    else:
        _vals = []
        for _r in _rows_for_agg:
            _nv = _num(_get_q(_r, _field_full, _field_base))
            if _nv is not None:
                _vals.append(_nv)

        if _func == 'sum':
            _val = sum(_vals) if _vals else 0
        elif _func == 'avg':
            _val = (sum(_vals) / len(_vals)) if _vals else None
        elif _func == 'min':
            _val = min(_vals) if _vals else None
        elif _func == 'max':
            _val = max(_vals) if _vals else None
        else:
            _val = None
    {% endif %}

    try:
        if _val is not None and isinstance(_val, (int, float)):
            {% if a.precision is defined and a.precision is not none %}
            _val = _safe_round(_val, {{ a.precision }})
            {% endif %}
    except Exception:
        pass

    result_aggs["{{ a.alias }}"] = _val
{% endfor %}
{% endif %}
    return result_aggs

if not HAS_GROUPS and not HAS_AGGS:
    results = []
    for row in filtered:
        out = {}
        {% if SEL_IS_STAR %}
        for k, v in row.items():
            out[k] = v
        {% elif SEL_IS_FIELDS and (FIELDS|length>0) %}
        {% for f in FIELDS %}
        out["{{ out_key_field(f) }}"] = _get_q(row, "{{ join_qname(f.name) }}", "{{ last_id(f.name) }}")
        {% endfor %}
        {% else %}
        for k, v in row.items():
            out[k] = v
        {% endif %}
        results.append(out)
else:
    groups = defaultdict(list)
    if HAS_GROUPS:
        for row in filtered:
            key = tuple(_get_q(row, GB_FULL[i], GB_BASE[i]) for i in range(len(GB_FULL)))
            groups[key].append(row)
    else:
        groups[None] = filtered

    results = []
    for key, rows in groups.items():
        result = {}

        if HAS_GROUPS:
            if isinstance(key, tuple):
                for i, g in enumerate(GB_OUT):
                    val = key[i]
                    result[g] = val
                    for _base, _alias in BASE_ALIAS.items():
                        if _alias == g and _base not in result:
                            result[_base] = val

        if HAS_AGGS:
            result.update(_compute_aggs_{{ QNAME }}(rows))

        results.append(result)

{% if query.orderBy and query.orderBy.items %}
{% for ob in query.orderBy.items | reverse %}
def _sort_key(val):
    if val is None:
        return (2, "")
    if isinstance(val, (int, float)):
        return (0, val)
    s = str(val).strip()
    num_like = s.replace('-', '', 1).replace('.', '', 1)
    if num_like.isdigit():
        try:
            return (0, float(s))
        except Exception:
            pass
    return (1, s.casefold())

results.sort(
    key=lambda r: _sort_key(_get_q(r, "{{ join_qname(ob.field) }}", "{{ last_id(ob.field) }}")),
    reverse={{ 'True' if (ob.direction is defined and ob.direction == 'desc') else 'False' }}
)
{% endfor %}
{% endif %}


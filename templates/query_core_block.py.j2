{% macro emit_operand(opnd) -%}
{%- if opnd is not defined or opnd is none -%}
None
{%- elif opnd.parts is defined -%}
_get_q(row, "{{ join_qname(opnd) }}", "{{ last_id(opnd) }}")
{%- else -%}
{{ py_value(opnd) }}
{%- endif -%}
